{
  "rules": {
    "config": {
      ".read": "auth != null",
      "contadorOS": {
        ".write": "auth != null"
      }
    },
    "usuarios": {
      ".read": "auth != null && root.child('usuarios').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('usuarios').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('usuarios').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "tecnicos": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('usuarios').child(auth.uid).child('role').val() === 'admin'"
    },
    "ordensServico": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "historico": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "categorias": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('usuarios').child(auth.uid).child('role').val() === 'admin'"
    },
    "setores": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('usuarios').child(auth.uid).child('role').val() === 'admin'"
    },
    "presenca": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "convites": {
      ".read": "auth != null",
      "$token": {
        ".read": true,
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('role').val() === 'admin'",
        "usado": {
          ".write": "auth != null"
        }
      }
    },
    "pins": {
      "$token": {
        ".read": true,
        ".write": "auth != null",
        "confirmado": {
          ".write": "root.child('pins').child($token).exists() && !root.child('pins').child($token).child('confirmado').val()"
        },
        "confirmacaoData": {
          ".write": "root.child('pins').child($token).exists() && !root.child('pins').child($token).child('confirmado').val()"
        },
        "userAgent": {
          ".write": "root.child('pins').child($token).exists() && !root.child('pins').child($token).child('confirmado').val()"
        }
      }
    }
  }
}
